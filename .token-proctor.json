{
  "$schema": "./.conductor.schema.json",
  "//": "Sample policy for end-to-end testing. Delete or rename to .conductor.off.json to disable.",
  "denyModels": ["claude-opus"],
  "premiumModelsAllowedFor": ["code_large", "reasoning"],
  "redact": {
    "builtins": true,
    "patterns": ["CORP-[A-Z0-9]{12}"],
    "blockOnMatch": false
  },
  "audit": {
    "enabled": true,
    "path": ".token-proctor/audit.jsonl"
  },
  "llmJudge": {
    "enabled": true,
    "confidenceThreshold": 0.85
  },
  "plan": {
    "name": "squad",
    "//": "Token-based plan: example 10M tokens/user/month, $5 overage per 1M.",
    "monthlyTokenAllowance": 10000000,
    "overageUsdPerM": 5.0
  },
  "completenessThreshold": 60,
  "preferCheap": true
}
